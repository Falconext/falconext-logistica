# Copia este archivo a .env.local y completa los valores. NO subir .env.local al repo.

# URL del backend (API). En local apunta al NestJS local; en producción (Vercel)
# ponla como la URL del proyecto del backend + /api, p. ej.:
#   https://logistica-api.vercel.app/api
NEXT_PUBLIC_API_URL=http://localhost:3005/api

# Token de Mapbox (todos los mapas: flota, operaciones, geocercas, historial)
NEXT_PUBLIC_MAPBOX_TOKEN=

# (Opcional / legado) Clave de Google Maps — ya no se usa, se migró todo a Mapbox.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
