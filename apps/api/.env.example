# Copia este archivo a .env y completa los valores. NO subir .env al repo.

# Base de datos (piloto: Postgres en Docker en :5439)
DATABASE_URL="postgresql://logistica:logistica_dev@localhost:5439/logistica?schema=public"

# Cloudinary (subida de fotos/documentos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (envío de correos/alertas)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Google Sheets: colocar el archivo google-credentials.json en apps/api/ (NO subir)
