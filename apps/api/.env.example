# Copia este archivo a .env y completa los valores. NO subir .env al repo.

# ── Base de datos ──────────────────────────────────────────────
# Local (Docker en :5439):
DATABASE_URL="postgresql://logistica:logistica_dev@localhost:5439/logistica?schema=public"
# En producción (Neon): usar la cadena CON pooler para la app...
#   DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.us-east-1.aws.neon.tech/logistica?sslmode=require"
# ...y la cadena DIRECTA (sin -pooler) para las migraciones de Prisma:
#   DIRECT_URL="postgresql://USER:PASS@ep-xxx.us-east-1.aws.neon.tech/logistica?sslmode=require"
DIRECT_URL=

# ── Seguridad ──────────────────────────────────────────────────
# Secreto para firmar los JWT (usa una cadena larga y aleatoria en producción)
JWT_SECRET=

# ── CORS ───────────────────────────────────────────────────────
# Dominio(s) del frontend permitido(s), separados por coma. Si se deja vacío se permite todo.
#   FRONTEND_URL="https://logistica-web.vercel.app"
FRONTEND_URL=

# ── Cloudinary (subida de fotos/documentos) ────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Resend (envío de correos/alertas) ──────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Google Sheets ──────────────────────────────────────────────
# Local: colocar google-credentials.json en apps/api/ (NO subir).
# Serverless (Vercel): pegar aquí el JSON de la service account (crudo o en base64).
GOOGLE_CREDENTIALS_JSON=
