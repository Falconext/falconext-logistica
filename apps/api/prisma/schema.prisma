
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  // "native" para desarrollo local; el target de Vercel (AWS Lambda) para producción.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // URL con pooling (Neon: ...-pooler...) para el runtime serverless.
  url       = env("DATABASE_URL")
  // URL directa (sin pooler) que Prisma usa para migraciones.
  directUrl = env("DIRECT_URL")
}

model Trabajador {
  id String @id @default(uuid())

  // Identificación Interna
  id_trabajador String? @unique @map("id_trabajador") // Custom ID from sheet if needed

  // Información Personal
  nombre_completo  String
  cargo            String
  estado_laboral   String  @default("Activo") // 'Activo', 'Inactivo'
  nacionalidad     String?
  fecha_nacimiento DateTime?
  url_foto         String?

  // Rastreo GPS: si el trabajador reporta su ubicación desde la app.
  // Al activarse se auto-provisiona un Device con token para este trabajador.
  trackable        Boolean @default(false)

  // Documentación Personal
  numero_pasaporte            String?
  fecha_vencimiento_pasaporte DateTime?

  documento_identidad         String?
  fecha_vencimiento_identidad DateTime?

  permiso_residencia           String?
  fecha_vencimiento_residencia DateTime?

  // Documentación Conducción
  licencia_conducir            String?
  fecha_vencimiento_licencia   DateTime?
  traduccion_licencia          String?
  fecha_vencimiento_traduccion DateTime?

  // Documentación Fiscal / Legal
  codigo_fiscal            String?
  fecha_vencimiento_fiscal DateTime?
  codigo_cu_2024           String?

  // Contratos
  tipo_contrato              String?
  fecha_vencimiento_contrato DateTime?
  dimision                   String? // Motivo o Fecha de salida
  
  // Contacto
  telefono           String?
  email_personal     String?
  direccion          String?
  area_trabajo       String?
  email_supervisor   String?
  
  // Financiero
  sueldo_base        Decimal? @default(0) // Added for payroll tracking

  // Otros
  permiso_univex     String?
  carta_responsiva   String?

  creado_en          DateTime @default(now())
  actualizado_en     DateTime @updatedAt
  
  tenant_id          String
  tenant             Tenant   @relation(fields: [tenant_id], references: [id])

  devices            Device[]

  @@map("trabajadores")
}

model Vehiculo {
  id             String @id @default(uuid())
  placa          String @unique // 'TARGA'

  // Detalles Técnicos
  marca_modelo        String?
  anio_fabricacion    Int?
  tipo_unidad         String? // 'DHL', 'Farmacia', etc.
  estado_vehiculo     String? // 'Activo', 'Mantenimiento'
  aislamiento_termico String? // 'COIBENTAZI'

  // Documentación
  tarjeta_circulacion      String? // 'LIBRETO'
  poliza_seguro            String? // 'ASEGURAZIONE'
  fecha_vencimiento_seguro DateTime? // Segunda columna de segurazione?
  revision_tecnica         String? // 'R.TECNICA'
  permisos_especiales      String? // 'DEROGHE'
  id_interno_furgon        String? // 'ID_FURGON'
  url_foto                 String? // Foto de la unidad (Cloudinary)

  // Telemetría y Rastreo (Futuro)
  kilometraje_actual Int?      @default(0)
  ultima_latitud     Float?
  ultima_longitud    Float?
  ultima_actualizacion DateTime?

  creado_en      DateTime @default(now())
  actualizado_en DateTime @updatedAt
  
  mantenimientos Mantenimiento[]

  tenant_id      String
  tenant         Tenant   @relation(fields: [tenant_id], references: [id])
  
  devices        Device[]

  @@map("vehiculos")
}

model Mantenimiento {
  id String @id @default(uuid())

  vehiculo_id String
  vehiculo    Vehiculo @relation(fields: [vehiculo_id], references: [id])

  tipo        String   // 'Preventivo', 'Correctivo', 'Emergencia'
  fecha       DateTime
  descripcion String
  costo       Float
  taller      String?

  kilometraje Int?
  evidence_url String? // URL de Cloudinary

  creado_en      DateTime @default(now())
  actualizado_en DateTime @updatedAt

  tenant_id      String
  tenant         Tenant   @relation(fields: [tenant_id], references: [id])

  @@map("mantenimiento")
}

model Programacion {
  id String @id @default(uuid())

  // Core info
  fecha            DateTime // 'FECHA'
  id_programacion  String?  @unique
  
  // Loose linking to allow ID_FURGON (e.g. F014) or PLACA
  vehiculo_id      String?  // 'MEZZO' (Could be F014 or Placa)
  trabajador_id    String?  // 'ID_AUTISTA'
  
  // Route Info
  cliente          String?  // 'CLIENTE'
  lugar_retiro     String?  // 'LUOGO RITIRO'
  fecha_retiro     DateTime? // New: Specific Date+Time for pickup
  
  lugar_entrega    String?  // 'LUOGO CONSEGNA'
  fecha_entrega    DateTime? // New: Specific Date+Time for delivery
  
  hora_retiro      String?  // Deprecated? Keep for legacy
  eta              String?  // Deprecated? Keep for legacy
  
  nota             String?  // 'NOTA'

  estado           String   @default("PENDING") // PENDING, IN_TRANSIT, COMPLETED, FAILED
  ingreso_estimado Float?   @default(0)

  creado_en        DateTime @default(now())
  actualizado_en   DateTime @updatedAt
  
  tenant_id        String
  tenant           Tenant   @relation(fields: [tenant_id], references: [id])

  @@map("programacion")
}

model Tenant {
  id    String @id @default(uuid())
  name  String
  slug  String @unique
  plan  String @default("FREE") // FREE, PRO, ENTERPRISE
  moneda String @default("EUR") // PEN | USD | EUR — moneda base de la empresa

  creado_en      DateTime @default(now())
  actualizado_en DateTime @updatedAt

  // Google Sheets Integration
  google_sheet_id String?
  last_synced     DateTime?

  users          User[]
  trabajadores   Trabajador[]
  vehiculos      Vehiculo[]
  mantenimientos Mantenimiento[]
  programaciones Programacion[]
  devices        Device[]
  geofences      Geofence[]
  peajes         Peaje[]
  combustibles   Combustible[]
  documentos     Documento[]
  roles          Rol[]

  @@map("tenants")
}

// Rol/puesto configurable por empresa. Define qué módulos ve el usuario y su
// comportamiento (administrador / solo sus propios registros).
model Rol {
  id           String  @id @default(uuid())
  nombre       String
  descripcion  String?
  modulos      String[] @default([]) // claves de módulos permitidos
  es_admin     Boolean @default(false) // ve todo y puede administrar usuarios/roles
  solo_propios Boolean @default(false) // los usuarios de este rol solo ven sus registros

  tenant_id String
  tenant    Tenant @relation(fields: [tenant_id], references: [id])
  usuarios  User[]

  creado_en      DateTime @default(now())
  actualizado_en DateTime @updatedAt

  @@unique([tenant_id, nombre])
  @@map("roles")
}

// Documento genérico: escaneos/archivos asociados a una entidad
// (VEHICULO | TRABAJADOR | MANTENIMIENTO). Soporta alertas por vencimiento.
model Documento {
  id          String  @id @default(uuid())
  entidad     String  // 'VEHICULO' | 'TRABAJADOR' | 'MANTENIMIENTO'
  entidad_id  String  // id del registro dueño
  tipo        String  // 'LICENCIA' | 'SEGURO' | 'TARJETA_CIRCULACION' | 'PASAPORTE' | 'REVISION_TECNICA' | 'OTRO'
  nombre      String?
  url         String? // URL de Cloudinary (imagen o PDF). Opcional: se puede
                      // registrar solo la fecha de vencimiento antes de subir el escaneo.
  fecha_vencimiento DateTime?

  creado_en      DateTime @default(now())
  actualizado_en DateTime @updatedAt

  tenant_id String
  tenant    Tenant @relation(fields: [tenant_id], references: [id])

  @@index([entidad, entidad_id])
  @@map("documentos")
}

model User {
  id        String @id @default(uuid())
  email     String @unique
  password  String
  role      String @default("VIEWER") // SUPERADMIN, ADMIN, USER (VIEWER legacy)
  nombre    String? // nombre visible del usuario
  activo    Boolean @default(true)
  modulos   String[] @default([]) // claves de módulos permitidos (los ADMIN ven todos)

  // Vínculo a un trabajador para filtrado por dueño (row-level)
  trabajador_id      String? // UUID del Trabajador vinculado (docs/alertas)
  trabajador_codigo  String? // id_trabajador (ej. G001) — clave en peajes/combustible/programacion
  solo_propios       Boolean @default(false) // override legacy; el rol es la fuente principal

  rol_id String? // rol/puesto asignado (define módulos y comportamiento)
  rol    Rol?    @relation(fields: [rol_id], references: [id])

  tenant_id String
  tenant    Tenant @relation(fields: [tenant_id], references: [id])

  creado_en      DateTime @default(now())
  actualizado_en DateTime @updatedAt

  @@map("users")
}

model Device {
  id              String   @id @default(uuid())
  imei            String   @unique // Identificador único del hardware/app
  name            String
  token           String   @unique @default(uuid()) // Token para autenticación del dispositivo
  model           String?  // Modelo del dispositivo
  last_activity   DateTime?
  
  // Relacion con el negocio
  id_programacion_actual String? // For sequential IDs (e.g. "R-001")

  vehiculo_id     String?  // Vehículo asignado actualmente
  vehiculo        Vehiculo? @relation(fields: [vehiculo_id], references: [id])

  trabajador_id   String?  // Conductor/trabajador que porta este dispositivo
  trabajador      Trabajador? @relation(fields: [trabajador_id], references: [id])

  tenant_id       String
  tenant          Tenant   @relation(fields: [tenant_id], references: [id])
  
  positions       Position[]
  geofence_events GeofenceEvent[]
  
  creado_en       DateTime @default(now())
  actualizado_en  DateTime @updatedAt

  @@map("devices")
}

model Position {
  id          String   @id @default(uuid())
  device_id   String
  device      Device   @relation(fields: [device_id], references: [id])
  
  latitude    Float
  longitude   Float
  speed       Float?   // km/h
  heading     Float?   // dirección en grados
  altitude    Float?
  accuracy    Float?
  
  battery     Int?     // Nivel de batería si aplica
  ignition    Boolean? // Si el motor está encendido
  
  timestamp   DateTime // Fecha real del reporte GPS
  server_time DateTime @default(now()) // Fecha de recepción en servidor

  @@index([device_id, timestamp])
  @@map("positions")
}

model Geofence {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        String   @default("CIRCLE") // CIRCLE, POLYGON
  
  // Para Circulo
  latitude    Float?
  longitude   Float?
  radius      Float?   // Metros
  
  // Para Poligono (GeoJSON stringified)
  coordinates String?

  tenant_id   String
  tenant      Tenant   @relation(fields: [tenant_id], references: [id])
  
  events      GeofenceEvent[]

  creado_en       DateTime @default(now())
  actualizado_en  DateTime @updatedAt

  @@map("geofences")
}

model GeofenceEvent {
  id          String   @id @default(uuid())
  geofence_id String
  geofence    Geofence @relation(fields: [geofence_id], references: [id])
  
  device_id   String
  device      Device   @relation(fields: [device_id], references: [id])
  
  event_type  String   // ENTER, EXIT
  timestamp   DateTime @default(now())
  
  @@index([device_id, timestamp])
  @@map("geofence_events")
}

// Peaje/Multa from sheet "MANCATO P."
model Peaje {
  id             String   @id @default(uuid())
  id_multa       String?  @unique  // 'Id_Multas'
  estado         String?           // 'ESTADO' (PAGADO, PENDIENTE, etc.)
  fecha          DateTime?         // 'FECHA'
  hora           String?           // 'HORA'
  targa          String?           // 'TARGA' (Vehicle plate)
  monto          Float?            // 'MONTO' (€ amount)
  trabajador_id  String?           // 'ID_ TRABAJADOR'
  comentarios    String?           // 'COMENTARIOS'
  archivo        String?           // 'ARCHIVO' (PDF link)
  recibo_pago    String?           // 'RECIBO DE PAGO'
  tipo           String?           // 'TIPO'
  mes            String?           // 'MES'
  fecha_recepcion DateTime?        // 'FECHA RECEPCIÓN'
  peaje_salida   String?           // 'PEAJE/SALIDA'
  nota_autista   String?           // 'NOTA AUTISTA'
  
  tenant_id      String
  tenant         Tenant   @relation(fields: [tenant_id], references: [id])
  
  creado_en      DateTime @default(now())
  actualizado_en DateTime @updatedAt
  
  @@index([trabajador_id])
  @@index([targa])
  @@map("peajes")
}

// Combustible from sheet "COMBUSTIBLE"
model Combustible {
  id              String   @id @default(uuid())
  id_registro     String?  @unique  // 'ID_REGISTRO'
  trabajador_id   String?           // 'ID_TRABAJADOR'
  fecha           DateTime?         // 'FECHA'
  monto           Float?            // 'MONTO'
  targa           String?           // 'TARGA'
  metodo          String?           // 'METODO' (AUTOBOT / IP, etc.)
  area            String?           // 'AREA' (DHL, FARMACIA)
  mes             String?           // 'MES'
  archivo         String?           // 'ARCHIVO' (Photo link)
  
  tenant_id       String
  tenant          Tenant   @relation(fields: [tenant_id], references: [id])
  
  creado_en       DateTime @default(now())
  actualizado_en  DateTime @updatedAt
  
  @@index([trabajador_id])
  @@index([targa])
  @@map("combustible")
}
